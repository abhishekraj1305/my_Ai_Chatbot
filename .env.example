# Optional Hugging Face generation. Keep real tokens only in .env or Space secrets.
ENABLE_HF_GENERATION=0
HF_TOKEN=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Default is fast vectorless retrieval. Use "chroma" only if optional vector deps
# are installed and you have already built vector_db with ingest.py.
RETRIEVAL_BACKEND=vectorless

# Protects the in-app Admin bookings panel.
ADMIN_PIN=

# Optional email alerts for new bookings.
# On hosted platforms such as Hugging Face Spaces, SMTP may be blocked.
# Prefer EMAIL_WEBHOOK_URL or RESEND_API_KEY for live email alerts.
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_SECRET=
EMAIL_FROM=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMTP still works for local runs and some hosts.
# For Gmail, use an App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
OWNER_EMAIL=

# Optional Google Calendar integration for real calendar busy checks/events.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_CALENDAR_ID=
BOOKING_TIMEZONE=Asia/Kolkata
BOOKING_DURATION_MINUTES=30
